<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yvliangbao.common.mapper.admin.PermissionInfoMapper">

    <resultMap id="BaseResultMap" type="com.yvliangbao.common.pojo.entity.admin.PermissionInfo">
        <id column="id" property="id"/>
        <result column="permission_code" property="permissionCode"/>
        <result column="permission_name" property="permissionName"/>
        <result column="permission_type" property="permissionType"/>
        <result column="parent_id" property="parentId"/>
        <result column="resource_url" property="resourceUrl"/>
        <result column="menu_path" property="menuPath"/>
        <result column="menu_icon" property="menuIcon"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据角色ID查询权限列表 -->
    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT p.*
        FROM permission_info p
        INNER JOIN role_permission rp ON p.id = rp.permission_id
        WHERE rp.role_id = #{roleId}
        AND p.deleted = 0
        AND p.status = 1
        ORDER BY p.sort_order
    </select>

    <!-- 查询所有启用的权限 -->
    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT *
        FROM permission_info
        WHERE deleted = 0
        AND status = 1
        ORDER BY sort_order
    </select>

    <!-- 根据管理员ID查询权限列表 -->
    <select id="selectByAdminId" resultMap="BaseResultMap">
        SELECT DISTINCT p.*
        FROM permission_info p
        INNER JOIN role_permission rp ON p.id = rp.permission_id
        INNER JOIN role_info r ON rp.role_id = r.id
        INNER JOIN admin_info a ON (
            FIND_IN_SET(r.id, a.role_ids) > 0 OR r.id = a.role_id
        )
        WHERE a.id = #{adminId}
        AND p.deleted = 0
        AND p.status = 1
        AND r.deleted = 0
        AND r.status = 1
        ORDER BY p.sort_order
    </select>

</mapper>
