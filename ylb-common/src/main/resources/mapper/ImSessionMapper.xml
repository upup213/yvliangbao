<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yvliangbao.common.mapper.im.ImSessionMapper">

    <resultMap id="SessionWithUserVOResultMap" type="com.yvliangbao.common.pojo.entity.im.ImSession">
        <id column="id" property="id"/>
        <result column="session_no" property="sessionNo"/>
        <result column="session_type" property="sessionType"/>
        <result column="user_id" property="userId"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="merchant_name" property="merchantName"/>
        <result column="store_id" property="storeId"/>
        <result column="store_name" property="storeName"/>
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="last_message" property="lastMessage"/>
        <result column="last_message_time" property="lastMessageTime"/>
        <result column="unread_user_count" property="unreadUserCount"/>
        <result column="unread_merchant_count" property="unreadMerchantCount"/>
        <result column="unread_platform_count" property="unreadPlatformCount"/>
        <result column="status" property="status"/>
        <result column="user_deleted" property="userDeleted"/>
        <result column="merchant_deleted" property="merchantDeleted"/>
        <result column="platform_deleted" property="platformDeleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
        <!-- 关联字段 -->
        <result column="user_nickname" property="userName"/>
        <result column="user_avatar" property="userAvatar"/>
        <result column="merchant_avatar" property="merchantAvatar"/>
    </resultMap>

    <!-- 用户端获取会话列表 -->
    <select id="getUserSessionsForUser" resultMap="SessionWithUserVOResultMap">
        SELECT s.*,
               m.merchant_name,
               m.id as merchant_avatar
        FROM im_session s
        LEFT JOIN merchant_info m ON s.merchant_id = m.id
        WHERE s.user_id = #{userId}
          AND s.user_deleted = 0
          AND s.status = 1
          AND s.session_type IN (1, 2)
        ORDER BY s.last_message_time DESC
    </select>

    <!-- 商户端获取会话列表 -->
    <select id="getUserSessionsForMerchant" resultMap="SessionWithUserVOResultMap">
        SELECT s.*,
               u.nickname as user_nickname,
               u.avatar as user_avatar
        FROM im_session s
        LEFT JOIN user_info u ON s.user_id = u.id
        WHERE s.merchant_id = #{merchantId}
          AND s.merchant_deleted = 0
          AND s.status = 1
          AND s.session_type IN (1, 3)
        ORDER BY s.last_message_time DESC
    </select>

    <!-- 平台端获取会话列表 -->
    <select id="getUserSessionsForPlatform" resultMap="SessionWithUserVOResultMap">
        SELECT s.*,
               u.nickname as user_nickname,
               u.avatar as user_avatar,
               m.merchant_name
        FROM im_session s
        LEFT JOIN user_info u ON s.user_id = u.id
        LEFT JOIN merchant_info m ON s.merchant_id = m.id
        WHERE s.platform_deleted = 0
          AND s.status = 1
        ORDER BY s.last_message_time DESC
    </select>

</mapper>
